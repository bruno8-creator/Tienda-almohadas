{% doc %}
  @prompt
    estilo moderno 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-modern-hero-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-modern-hero-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: {{ block.settings.section_height }}px;
    gap: 40px;
    align-items: center;
    padding: 60px;
  }

  .ai-modern-hero-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 2;
  }

  .ai-modern-hero-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.eyebrow_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
  }

  .ai-modern-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.1;
    margin: 0;
    font-weight: 700;
  }

  .ai-modern-hero-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    max-width: 500px;
  }

  .ai-modern-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ai-modern-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: 2px solid transparent;
  }

  .ai-modern-hero-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text_color }};
  }

  .ai-modern-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-modern-hero-button-secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.secondary_button_text_color }};
    border-color: {{ block.settings.secondary_button_border }};
  }

  .ai-modern-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_border }};
    color: {{ block.settings.background_color }};
  }

  .ai-modern-hero-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-modern-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-modern-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-modern-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-modern-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-modern-hero-accent-{{ ai_gen_id }} {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: {{ block.settings.accent_color }};
    opacity: 0.1;
    filter: blur(80px);
    pointer-events: none;
  }

  .ai-modern-hero-accent-1-{{ ai_gen_id }} {
    top: -100px;
    right: -100px;
  }

  .ai-modern-hero-accent-2-{{ ai_gen_id }} {
    bottom: -100px;
    left: -100px;
  }

  @media screen and (max-width: 749px) {
    .ai-modern-hero-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      padding: 40px 20px;
      gap: 30px;
      min-height: auto;
    }

    .ai-modern-hero-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-modern-hero-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-modern-hero-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-modern-hero-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-modern-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-modern-hero-accent-{{ ai_gen_id }} ai-modern-hero-accent-1-{{ ai_gen_id }}"></div>
  <div class="ai-modern-hero-accent-{{ ai_gen_id }} ai-modern-hero-accent-2-{{ ai_gen_id }}"></div>
  
  <div class="ai-modern-hero-container-{{ ai_gen_id }}">
    <div class="ai-modern-hero-content-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-modern-hero-eyebrow-{{ ai_gen_id }}">
          {{ block.settings.eyebrow }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h1 class="ai-modern-hero-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h1>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-modern-hero-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      <div class="ai-modern-hero-buttons-{{ ai_gen_id }}">
        {% if block.settings.primary_button_label != blank %}
          <a 
            href="{{ block.settings.primary_button_link }}" 
            class="ai-modern-hero-button-{{ ai_gen_id }} ai-modern-hero-button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.primary_button_label }}
          </a>
        {% endif %}

        {% if block.settings.secondary_button_label != blank %}
          <a 
            href="{{ block.settings.secondary_button_link }}" 
            class="ai-modern-hero-button-{{ ai_gen_id }} ai-modern-hero-button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-modern-hero-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-modern-hero-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-modern-hero-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-modern-hero-empty-state-{{ ai_gen_id }}">
            Añade una imagen para completar tu hero moderno
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero moderno",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "inline_richtext",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Nuevo"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Título",
      "default": "Diseño moderno y elegante"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Descubre nuestra colección con un estilo contemporáneo que combina funcionalidad y estética minimalista.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "header",
      "content": "Botón principal"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Texto del botón",
      "default": "Explorar ahora"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "Botón secundario"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Texto del botón",
      "default": "Más información"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Altura mínima",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Radio de borde imagen",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Radio de borde botones",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#6366F1"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color texto superior",
      "default": "#6366F1"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color título",
      "default": "#1F2937"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color texto",
      "default": "#6B7280"
    },
    {
      "type": "header",
      "content": "Botón principal"
    },
    {
      "type": "color",
      "id": "primary_button_bg",
      "label": "Fondo",
      "default": "#1F2937"
    },
    {
      "type": "color",
      "id": "primary_button_hover_bg",
      "label": "Fondo al pasar",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "primary_button_text_color",
      "label": "Texto",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Botón secundario"
    },
    {
      "type": "color",
      "id": "secondary_button_text_color",
      "label": "Texto",
      "default": "#1F2937"
    },
    {
      "type": "color",
      "id": "secondary_button_border",
      "label": "Borde",
      "default": "#E5E7EB"
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Tamaño texto superior",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño título",
      "min": 30,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Tamaño texto",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    }
  ],
  "presets": [
    {
      "name": "Hero moderno"
    }
  ]
}
{% endschema %}