{% liquid
  assign featured_product = all_products['air-cushion-pillows-outdoor-camping-folding-square-lnflatable-pillows-travel-backrest-plane-head-rest-pillow-camping']
  assign product_url = '/products/air-cushion-pillows-outdoor-camping-folding-square-lnflatable-pillows-travel-backrest-plane-head-rest-pillow-camping?variant=54547796820310'
  if featured_product != blank
    assign product_url = featured_product.selected_or_first_available_variant.url
  endif
%}

<section class="kivo-home full-width">
  <div class="kivo-hero">
    <div class="kivo-hero__copy kivo-reveal">
      <p class="kivo-eyebrow">KivoRest comfort essentials</p>
      <h1>Rest that travels with you.</h1>
      <p class="kivo-lede">
        Smart, compact comfort products designed for travel days, outdoor plans, long commutes, and better pauses wherever
        life takes you.
      </p>
      <div class="kivo-actions">
        <a class="kivo-button" href="#kivo-products">Shop products</a>
        <a class="kivo-button kivo-button--ghost" href="#kivo-benefits">Why KivoRest</a>
      </div>
      <div class="kivo-proof" aria-label="KivoRest highlights">
        <span>Travel-ready</span>
        <span>Lightweight comfort</span>
        <span>Everyday recovery</span>
      </div>
    </div>

    <div class="kivo-hero__visual kivo-reveal" aria-hidden="true">
      <div class="kivo-orbit"></div>
      <div class="kivo-brand-mark">
        <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="" width="720" height="720">
      </div>
      <div class="kivo-floating-card kivo-floating-card--top">
        <strong>Compact by design</strong>
        <span>Built for bags, cabins, cars, and outdoor setups.</span>
      </div>
      <div class="kivo-floating-card kivo-floating-card--bottom">
        <strong>Comfort first</strong>
        <span>Products chosen for practical support and easy routines.</span>
      </div>
    </div>
  </div>

  <div id="kivo-benefits" class="kivo-benefits">
    <article class="kivo-benefit kivo-reveal">
      <span>01</span>
      <h2>Made for movement</h2>
      <p>Comfort products that are easy to pack, carry, use, and store.</p>
    </article>
    <article class="kivo-benefit kivo-reveal">
      <span>02</span>
      <h2>Simple to choose</h2>
      <p>Clear product pages, useful details, and no overcomplicated buying flow.</p>
    </article>
    <article class="kivo-benefit kivo-reveal">
      <span>03</span>
      <h2>Designed to feel light</h2>
      <p>A clean store experience with soft visuals, calm motion, and focused product discovery.</p>
    </article>
  </div>

  <div class="kivo-showcase kivo-reveal">
    <div>
      <p class="kivo-eyebrow">Built around better breaks</p>
      <h2>Portable comfort for trips, workdays, and outdoor moments.</h2>
    </div>
    <div class="kivo-showcase__grid">
      <div><strong>Travel</strong><span>Comfort support for planes, cars, trains, and luggage-light trips.</span></div>
      <div><strong>Outdoor</strong><span>Useful for camping, beach days, picnics, and short rests.</span></div>
      <div><strong>Daily</strong><span>Small upgrades for commutes, naps, and quiet reset moments.</span></div>
      <div><strong>Giftable</strong><span>Practical products with a friendly, modern brand feel.</span></div>
    </div>
  </div>

  <div id="kivo-products" class="kivo-products kivo-reveal">
    <div class="kivo-products__header">
      <p class="kivo-eyebrow">Products</p>
      <h2>Shop KivoRest</h2>
      <p>More comfort essentials are coming soon. Start with our first travel-ready product.</p>
    </div>

    <div class="kivo-products__grid">
      <a class="kivo-product-card" href="{{ product_url }}">
        <div class="kivo-product-card__media">
          {% if featured_product.featured_image %}
            {{ featured_product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
          {% else %}
            <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="720" height="720">
          {% endif %}
        </div>
        <div class="kivo-product-card__content">
          <span>Available now</span>
          <h3>{{ featured_product.title | default: 'Inflatable Travel Pillow' }}</h3>
          <p>Inflatable, compact support for travel, camping, and quick rest stops.</p>
          <strong>{{ featured_product.price | default: 295 | money }}</strong>
        </div>
      </a>

      <div class="kivo-product-card kivo-product-card--soon" aria-label="More KivoRest products coming soon">
        <div class="kivo-product-card__media">
          <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="" width="720" height="720">
        </div>
        <div class="kivo-product-card__content">
          <span>Coming soon</span>
          <h3>More comfort essentials</h3>
          <p>New portable rest products will be added here as the KivoRest collection grows.</p>
          <strong>Stay tuned</strong>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .kivo-home {
    overflow: hidden;
    padding: 2rem 0 5rem;
  }

  .kivo-home h1,
  .kivo-home h2,
  .kivo-home h3 {
    color: #102033;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .kivo-hero,
  .kivo-benefits,
  .kivo-showcase,
  .kivo-products {
    width: min(1180px, calc(100% - 32px));
    margin-inline: auto;
  }

  .kivo-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(320px, 1.02fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    min-height: calc(100svh - 7.5rem);
    padding: clamp(2rem, 5vw, 5rem) 0;
  }

  .kivo-eyebrow {
    color: #2c91ff;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .kivo-hero h1 {
    max-width: 10ch;
    margin-top: 1rem;
    font-size: clamp(3.6rem, 8vw, 8rem);
  }

  .kivo-lede {
    max-width: 42rem;
    margin-top: 1.4rem;
    color: #52657a;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
  }

  .kivo-actions,
  .kivo-proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .kivo-proof {
    gap: 0.7rem;
    margin-top: 1.4rem;
  }

  .kivo-proof span {
    border: 1px solid rgba(44, 145, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: #52657a;
    font-weight: 800;
    padding: 0.55rem 0.8rem;
  }

  .kivo-hero__visual {
    position: relative;
    min-height: clamp(25rem, 52vw, 42rem);
    display: grid;
    place-items: center;
  }

  .kivo-orbit {
    position: absolute;
    width: min(92%, 36rem);
    aspect-ratio: 1;
    border: 1px solid rgba(44, 145, 255, 0.22);
    border-radius: 999px;
    animation: kivo-spin 18s linear infinite;
  }

  .kivo-orbit::before,
  .kivo-orbit::after {
    content: "";
    position: absolute;
    width: 0.75rem;
    aspect-ratio: 1;
    border-radius: 999px;
    background: #2c91ff;
    box-shadow: 0 0 24px rgba(44, 145, 255, 0.7);
  }

  .kivo-orbit::before {
    top: 7%;
    left: 18%;
  }

  .kivo-orbit::after {
    right: 8%;
    bottom: 20%;
  }

  .kivo-brand-mark {
    position: relative;
    z-index: 2;
    display: grid;
    width: min(82%, 30rem);
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid rgba(44, 145, 255, 0.16);
    border-radius: 48px;
    background:
      radial-gradient(circle at 50% 25%, rgba(115, 192, 255, 0.26), transparent 14rem),
      rgba(255, 255, 255, 0.72);
    box-shadow: 0 36px 80px rgba(35, 107, 184, 0.16);
    animation: kivo-float 5.4s ease-in-out infinite;
  }

  .kivo-brand-mark img {
    width: 72%;
    border-radius: 34px;
  }

  .kivo-floating-card {
    position: absolute;
    z-index: 3;
    width: min(15rem, 45vw);
    border: 1px solid rgba(44, 145, 255, 0.18);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 22px 60px rgba(34, 91, 160, 0.14);
    backdrop-filter: blur(16px);
    padding: 1rem;
  }

  .kivo-floating-card strong,
  .kivo-floating-card span {
    display: block;
  }

  .kivo-floating-card strong {
    color: #102033;
  }

  .kivo-floating-card span {
    color: #64778c;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .kivo-floating-card--top {
    top: 8%;
    right: 0;
  }

  .kivo-floating-card--bottom {
    bottom: 8%;
    left: 0;
  }

  .kivo-benefits,
  .kivo-products__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .kivo-benefit,
  .kivo-showcase,
  .kivo-products,
  .kivo-product-card {
    border: 1px solid rgba(44, 145, 255, 0.13);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 24px 70px rgba(34, 91, 160, 0.1);
  }

  .kivo-benefit {
    padding: 1.35rem;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .kivo-benefit:hover,
  .kivo-product-card:hover {
    box-shadow: 0 28px 80px rgba(34, 91, 160, 0.16);
    transform: translateY(-5px);
  }

  .kivo-benefit span {
    color: #2c91ff;
    font-weight: 900;
  }

  .kivo-benefit h2 {
    margin-top: 1.6rem;
    font-size: 1.55rem;
  }

  .kivo-benefit p,
  .kivo-products__header p {
    margin-top: 0.8rem;
    color: #64778c;
  }

  .kivo-showcase,
  .kivo-products {
    margin-top: 1rem;
    padding: clamp(1.25rem, 4vw, 3rem);
  }

  .kivo-showcase {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 2rem;
    align-items: center;
  }

  .kivo-showcase h2,
  .kivo-products__header h2 {
    margin-top: 0.8rem;
    font-size: clamp(2.2rem, 4vw, 4.8rem);
  }

  .kivo-showcase__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }

  .kivo-showcase__grid div {
    min-height: 9rem;
    border-radius: 24px;
    background: linear-gradient(145deg, #edf7ff, #ffffff);
    padding: 1rem;
  }

  .kivo-showcase__grid strong,
  .kivo-showcase__grid span {
    display: block;
  }

  .kivo-showcase__grid strong {
    color: #102033;
    font-size: 1.35rem;
  }

  .kivo-showcase__grid span {
    color: #64778c;
    margin-top: 0.45rem;
  }

  .kivo-products__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .kivo-product-card {
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .kivo-product-card__media {
    display: grid;
    min-height: 24rem;
    place-items: center;
    background:
      radial-gradient(circle at 50% 8%, rgba(115, 192, 255, 0.28), transparent 14rem),
      #f7fbff;
  }

  .kivo-product-card__media img {
    width: 100%;
    max-height: 24rem;
    object-fit: contain;
    padding: 1.2rem;
    transition: transform 220ms ease;
  }

  .kivo-product-card:hover .kivo-product-card__media img {
    transform: scale(1.035);
  }

  .kivo-product-card--soon .kivo-product-card__media img {
    width: min(60%, 18rem);
    border-radius: 28px;
    opacity: 0.7;
  }

  .kivo-product-card__content {
    padding: 1.25rem;
  }

  .kivo-product-card__content span {
    color: #2c91ff;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kivo-product-card__content h3 {
    margin-top: 0.55rem;
    font-size: clamp(1.7rem, 3vw, 2.7rem);
  }

  .kivo-product-card__content p {
    color: #64778c;
    margin-top: 0.65rem;
  }

  .kivo-product-card__content strong {
    display: block;
    color: #102033;
    font-size: 1.35rem;
    margin-top: 1rem;
  }

  .kivo-reveal {
    animation: kivo-rise 700ms ease both;
  }

  .kivo-reveal:nth-child(2) {
    animation-delay: 100ms;
  }

  @keyframes kivo-rise {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes kivo-float {
    0%,
    100% {
      transform: translateY(0) rotate(-1deg);
    }
    50% {
      transform: translateY(-16px) rotate(1deg);
    }
  }

  @keyframes kivo-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 900px) {
    .kivo-hero,
    .kivo-showcase {
      grid-template-columns: 1fr;
    }

    .kivo-hero h1 {
      max-width: 12ch;
    }

    .kivo-benefits,
    .kivo-products__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .kivo-home {
      padding-top: 0.5rem;
    }

    .kivo-hero {
      min-height: auto;
      padding-top: 1rem;
    }

    .kivo-hero h1 {
      font-size: 3.45rem;
    }

    .kivo-showcase__grid {
      grid-template-columns: 1fr;
    }

    .kivo-floating-card {
      position: relative;
      inset: auto;
      width: 100%;
      margin-top: 0.75rem;
    }

    .kivo-hero__visual {
      min-height: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "KivoRest home v2",
  "settings": [],
  "presets": [
    {
      "name": "KivoRest home v2"
    }
  ]
}
{% endschema %}
