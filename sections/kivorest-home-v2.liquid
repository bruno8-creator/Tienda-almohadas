{% liquid
  assign featured_product = all_products['air-cushion-pillows-outdoor-camping-folding-square-lnflatable-pillows-travel-backrest-plane-head-rest-pillow-camping']
  assign product_url = '/products/air-cushion-pillows-outdoor-camping-folding-square-lnflatable-pillows-travel-backrest-plane-head-rest-pillow-camping?variant=54547796820310'
  if featured_product != blank
    assign product_url = featured_product.selected_or_first_available_variant.url
  endif
%}

<section class="kivo-storefront full-width">
  <div class="kivo-storebar">
    <span>Secure Shopify checkout</span>
    <span>Travel comfort essentials</span>
    <span>Curated product catalog</span>
  </div>

  <div class="kivo-shop-hero">
    <div>
      <p class="kivo-eyebrow">KivoRest store</p>
      <h1>Portable comfort essentials.</h1>
      <p>
        Shop compact rest products for travel, outdoor plans, commutes, and everyday breaks. The catalog is starting
        small and built to grow product by product.
      </p>
    </div>
    <div class="kivo-shop-hero__aside">
      <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="180" height="180">
      <strong>Clean. Compact. Ready to go.</strong>
    </div>
  </div>

  <div class="kivo-category-row" aria-label="Product categories">
    <a href="#kivo-products">All products</a>
  </div>

  <div id="kivo-products" class="kivo-catalog">
    <div class="kivo-catalog__header">
      <div>
        <p class="kivo-eyebrow">Products</p>
        <h2>Shop all</h2>
      </div>
      <p>{{ collections.all.products_count | default: 1 }} item available</p>
    </div>

    <div class="kivo-product-grid">
      {% if featured_product != blank %}
        <a class="kivo-product-tile" href="{{ product_url }}">
          <div class="kivo-product-tile__image">
            {{ featured_product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
          </div>
          <div class="kivo-product-tile__body">
            <span class="kivo-product-tile__badge">In stock</span>
            <h3>{{ featured_product.title }}</h3>
            <p>Inflatable support for flights, road trips, camping, and quick rest stops.</p>
            <div class="kivo-product-tile__footer">
              <strong>{{ featured_product.price | money }}</strong>
              <span>View product</span>
            </div>
          </div>
        </a>
      {% endif %}
    </div>
  </div>

  <div class="kivo-store-info">
    <article>
      <strong>Secure checkout</strong>
      <p>Checkout is handled by Shopify after customers add products to cart.</p>
    </article>
    <article>
      <strong>Product-first layout</strong>
      <p>The store is organized around a scalable grid so new products can be added naturally.</p>
    </article>
    <article>
      <strong>Mobile friendly</strong>
      <p>Product cards, photos, and checkout actions are designed for quick browsing on phones.</p>
    </article>
  </div>
</section>

{% stylesheet %}
  .kivo-storefront {
    position: relative;
    isolation: isolate;
    padding: 1rem 0 5rem;
  }

  .kivo-storefront::before,
  .kivo-storefront::after {
    content: "";
    position: absolute;
    z-index: -1;
    width: min(44vw, 34rem);
    aspect-ratio: 1.25;
    border-radius: 42% 58% 63% 37% / 48% 43% 57% 52%;
    background: rgba(93, 180, 255, 0.18);
    filter: blur(10px);
    pointer-events: none;
    animation: kivo-liquid-drift 12s ease-in-out infinite alternate;
  }

  .kivo-storefront::before {
    top: 4rem;
    right: -8rem;
  }

  .kivo-storefront::after {
    bottom: 10rem;
    left: -10rem;
    background: rgba(44, 145, 255, 0.12);
    animation-delay: -4s;
  }

  .kivo-storefront h1,
  .kivo-storefront h2,
  .kivo-storefront h3 {
    color: #102033;
    letter-spacing: 0;
    line-height: 1;
  }

  .kivo-storebar,
  .kivo-shop-hero,
  .kivo-category-row,
  .kivo-catalog,
  .kivo-store-info {
    width: min(1180px, calc(100% - 32px));
    margin-inline: auto;
  }

  .kivo-storebar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding-top: 0.5rem;
  }

  .kivo-storebar span,
  .kivo-category-row a,
  .kivo-product-tile__badge {
    border: 1px solid rgba(44, 145, 255, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    color: #315f8f;
    font-size: 0.8rem;
    font-weight: 900;
    padding: 0.5rem 0.75rem;
    text-decoration: none;
  }

  .kivo-shop-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.7fr);
    gap: 1rem;
    align-items: stretch;
    margin-top: 1rem;
  }

  .kivo-shop-hero > div,
  .kivo-catalog,
  .kivo-store-info article {
    border: 1px solid rgba(44, 145, 255, 0.13);
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 70px rgba(34, 91, 160, 0.1);
    backdrop-filter: blur(18px);
  }

  .kivo-shop-hero > div:first-child {
    padding: clamp(1.4rem, 4vw, 3rem);
  }

  .kivo-eyebrow {
    color: #2c91ff;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .kivo-shop-hero h1 {
    max-width: 11ch;
    margin-top: 0.75rem;
    font-size: clamp(3rem, 6vw, 6.5rem);
  }

  .kivo-shop-hero p:not(.kivo-eyebrow) {
    max-width: 46rem;
    margin-top: 1rem;
    color: #52657a;
    font-size: 1.08rem;
  }

  .kivo-shop-hero__aside {
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 1rem;
    padding: 1.5rem;
    text-align: center;
  }

  .kivo-shop-hero__aside img {
    width: min(70%, 13rem);
    border-radius: 30px;
  }

  .kivo-shop-hero__aside strong {
    max-width: 15rem;
    color: #102033;
    font-size: 1.4rem;
    line-height: 1.1;
  }

  .kivo-category-row {
    display: flex;
    gap: 0.55rem;
    overflow-x: auto;
    padding: 1rem 0 0.2rem;
  }

  .kivo-category-row a {
    flex: 0 0 auto;
  }

  .kivo-catalog {
    margin-top: 1rem;
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .kivo-catalog__header {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    padding: 0.25rem 0.25rem 1.2rem;
  }

  .kivo-catalog__header h2 {
    margin-top: 0.35rem;
    font-size: clamp(2rem, 4vw, 4rem);
  }

  .kivo-catalog__header > p {
    color: #64778c;
    font-weight: 800;
  }

  .kivo-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(16rem, 100%), 1fr));
    gap: 1rem;
  }

  .kivo-product-tile {
    overflow: hidden;
    display: flex;
    min-width: 0;
    flex-direction: column;
    border: 1px solid rgba(44, 145, 255, 0.13);
    border-radius: 22px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .kivo-product-tile:hover {
    box-shadow: 0 22px 55px rgba(34, 91, 160, 0.15);
    transform: translateY(-4px);
  }

  .kivo-product-tile__image {
    display: grid;
    aspect-ratio: 1;
    place-items: center;
    background:
      radial-gradient(circle at 50% 12%, rgba(115, 192, 255, 0.28), transparent 12rem),
      #f7fbff;
  }

  .kivo-product-tile__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.8rem;
    transition: transform 220ms ease;
  }

  .kivo-product-tile:hover .kivo-product-tile__image img {
    transform: scale(1.035);
  }

  .kivo-product-tile__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1rem;
  }

  .kivo-product-tile__badge {
    align-self: flex-start;
    padding: 0.42rem 0.6rem;
  }

  .kivo-product-tile h3 {
    margin-top: 0.75rem;
    font-size: 1.25rem;
    line-height: 1.1;
  }

  .kivo-product-tile p {
    color: #64778c;
    font-size: 0.92rem;
    margin-top: 0.55rem;
  }

  .kivo-product-tile__footer {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1rem;
  }

  .kivo-product-tile__footer strong {
    color: #102033;
    font-size: 1.1rem;
  }

  .kivo-product-tile__footer span {
    color: #2c91ff;
    font-size: 0.88rem;
    font-weight: 900;
  }

  .kivo-store-info {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .kivo-store-info article {
    padding: 1rem;
  }

  .kivo-store-info strong {
    display: block;
    color: #102033;
    font-size: 1.1rem;
  }

  .kivo-store-info p {
    color: #64778c;
    margin-top: 0.45rem;
  }

  @keyframes kivo-liquid-drift {
    from {
      border-radius: 42% 58% 63% 37% / 48% 43% 57% 52%;
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
    to {
      border-radius: 62% 38% 43% 57% / 39% 61% 39% 61%;
      transform: translate3d(1.5rem, -1rem, 0) rotate(8deg);
    }
  }

  @media (max-width: 980px) {
    .kivo-product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .kivo-shop-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .kivo-shop-hero h1 {
      font-size: 3.25rem;
    }

    .kivo-catalog__header,
    .kivo-product-tile__footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .kivo-product-grid,
    .kivo-store-info {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "KivoRest storefront grid",
  "settings": [],
  "presets": [
    {
      "name": "KivoRest storefront grid"
    }
  ]
}
{% endschema %}
