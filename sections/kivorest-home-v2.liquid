<section class="kivo-storefront full-width">
  <div class="kivo-storebar">
    <span>50% off in cart</span>
    <span>Secure Shopify checkout</span>
    <span>Easy cart review</span>
  </div>

  <div class="kivo-shop-hero">
    <div>
      <p class="kivo-eyebrow">KivoRest launch offer</p>
      <h1>Travel comfort, lighter.</h1>
      <p>
        Compact inflatable pillows for trips, home rest, camping, and quick breaks.
      </p>
    </div>
    <div class="kivo-shop-hero__aside">
      <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="180" height="180">
      <strong>50% applied at cart.</strong>
    </div>
  </div>

  <div id="kivo-products" class="kivo-catalog">
    <div class="kivo-catalog__header">
      <div>
        <p class="kivo-eyebrow">Products</p>
        <h2>Shop all</h2>
      </div>
      <p>{{ collections.all.products_count | default: 1 }} items available</p>
    </div>

    <div class="kivo-product-grid">
      {% for product_item in collections.all.products %}
        {% liquid
          assign kivo_discount_percent = 50
          assign kivo_discount_multiplier = 100 | minus: kivo_discount_percent
          assign product_campaign_price = product_item.price | times: kivo_discount_multiplier | plus: 50 | divided_by: 100
          assign product_summary = 'Inflatable support for flights, road trips, camping, and quick rest stops.'
          assign product_badge = '50% off in cart'
          if product_item.handle contains 'wedge'
            assign product_summary = 'Adjustable wedge support for your back, legs, arms, home, office, and travel.'
          endif
        %}
        <a class="kivo-product-tile" href="{{ product_item.url }}">
          <div class="kivo-product-tile__image">
            {{ product_item.featured_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
          </div>
          <div class="kivo-product-tile__body">
            <span class="kivo-product-tile__badge">{{ product_badge }}</span>
            <h3>{{ product_item.title }}</h3>
            <p>{{ product_summary }}</p>
            <div class="kivo-product-tile__footer">
              <strong>
                {{ product_campaign_price | money }}
                <s>{{ product_item.price | money }}</s>
              </strong>
              <span>View product</span>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>

  <div class="kivo-confidence-strip" aria-label="Store confidence highlights">
    <article>
      <span>01</span>
      <strong>Protected checkout</strong>
      <p>Shopify secure checkout.</p>
    </article>
    <article>
      <span>02</span>
      <strong>Real product media</strong>
      <p>Photos and variants shown clearly.</p>
    </article>
    <article>
      <span>03</span>
      <strong>Cart control</strong>
      <p>Edit quantity before paying.</p>
    </article>
  </div>

  <div class="kivo-store-info">
    <article>
      <strong>Secure checkout</strong>
      <p>Checkout is handled by Shopify after customers add products to cart.</p>
    </article>
    <article>
      <strong>Product-first layout</strong>
      <p>The store is organized around a scalable grid so new products can be added naturally.</p>
    </article>
    <article>
      <strong>Mobile friendly</strong>
      <p>Product cards, photos, and checkout actions are designed for quick browsing on phones.</p>
    </article>
  </div>

  <div id="kivo-confidence" class="kivo-trust-panel">
    <div class="kivo-section-heading">
      <div>
        <p class="kivo-eyebrow">Trust</p>
        <h2>Shop with confidence.</h2>
      </div>
    </div>
    <div class="kivo-trust-grid">
      <article>
        <span>&#10003;</span>
        <strong>Secure checkout</strong>
      </article>
      <article>
        <span>&#10003;</span>
        <strong>Variant selection</strong>
      </article>
      <article>
        <span>&#10003;</span>
        <strong>Photo gallery</strong>
      </article>
      <article>
        <span>&#10003;</span>
        <strong>Real catalog</strong>
      </article>
      <article>
        <span>&#10003;</span>
        <strong>Easy cart edits</strong>
      </article>
      <article>
        <span>&#10003;</span>
        <strong>Mobile ready</strong>
      </article>
    </div>
  </div>

  <div id="kivo-faq" class="kivo-faq">
    <div class="kivo-section-heading">
      <div>
        <p class="kivo-eyebrow">Questions</p>
        <h2>Quick answers before you buy.</h2>
      </div>
    </div>
    <div class="kivo-faq-list">
      <details open>
        <summary>Can I choose the color before checkout?</summary>
        <p>Yes. Open the product page, choose the color variant, then add it to cart.</p>
      </details>
      <details>
        <summary>Can I review my cart before paying?</summary>
        <p>Yes. The add-to-cart flow takes you to the cart, where you can update quantity or remove the item.</p>
      </details>
      <details>
        <summary>Will more products be added later?</summary>
        <p>Yes. The store is built as a product grid so the catalog can grow naturally.</p>
      </details>
    </div>
  </div>
</section>

{% stylesheet %}
  .kivo-storefront {
    position: relative;
    isolation: isolate;
    padding: 0.55rem 0 4rem;
  }

  .kivo-storefront::before,
  .kivo-storefront::after {
    content: none;
    position: absolute;
    z-index: -1;
    width: min(44vw, 34rem);
    aspect-ratio: 1.25;
    border-radius: 42% 58% 63% 37% / 48% 43% 57% 52%;
    background: rgba(93, 180, 255, 0.18);
    filter: blur(10px);
    pointer-events: none;
    animation: kivo-liquid-drift 12s ease-in-out infinite alternate;
  }

  .kivo-storefront::before {
    top: 4rem;
    right: -8rem;
  }

  .kivo-storefront::after {
    bottom: 10rem;
    left: -10rem;
    background: rgba(44, 145, 255, 0.12);
    animation-delay: -4s;
  }

  .kivo-storefront h1,
  .kivo-storefront h2,
  .kivo-storefront h3 {
    color: #102033;
    letter-spacing: 0;
    line-height: 1;
  }

  .kivo-storebar,
  .kivo-shop-hero,
  .kivo-catalog,
  .kivo-store-info,
  .kivo-confidence-strip,
  .kivo-trust-panel,
  .kivo-faq {
    width: min(1180px, calc(100% - 32px));
    margin-inline: auto;
  }

  .kivo-storebar {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding-top: 0.25rem;
  }

  .kivo-storebar span,
  .kivo-product-tile__badge {
    border: 1px solid #111111;
    border-radius: 0;
    background: #ffffff;
    color: #111111;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    padding: 0.42rem 0.7rem;
    text-decoration: none;
    text-transform: uppercase;
  }

  .kivo-storebar span:first-child,
  .kivo-product-tile__badge {
    background: #111111;
    color: #ffffff;
  }

  .kivo-shop-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: stretch;
    margin-top: 0.55rem;
  }

  .kivo-shop-hero > div,
  .kivo-catalog,
  .kivo-store-info article {
    border: 1px solid rgba(44, 145, 255, 0.13);
    border-radius: 0;
    background: #ffffff;
    box-shadow: none;
    backdrop-filter: none;
  }

  .kivo-shop-hero > div:first-child {
    padding: clamp(0.9rem, 2vw, 1.25rem);
  }

  .kivo-eyebrow {
    color: #111111;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .kivo-shop-hero h1 {
    max-width: 20ch;
    margin-top: 0.35rem;
    font-size: clamp(2rem, 4vw, 4rem);
  }

  .kivo-shop-hero p:not(.kivo-eyebrow) {
    max-width: 46rem;
    margin-top: 0.45rem;
    color: #444444;
    font-size: 0.98rem;
  }

  .kivo-shop-hero__aside {
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 1rem;
    min-width: 12rem;
    padding: 0.9rem;
    text-align: center;
  }

  .kivo-shop-hero__aside img {
    width: 4rem;
    border-radius: 10px;
  }

  .kivo-shop-hero__aside strong {
    max-width: 10rem;
    color: #102033;
    font-size: 1.05rem;
    line-height: 1.1;
  }

  .kivo-catalog {
    margin-top: 0.75rem;
    padding: clamp(0.8rem, 2vw, 1.1rem);
  }

  .kivo-confidence-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
    margin-top: 0.75rem;
  }

  .kivo-confidence-strip article,
  .kivo-trust-grid article,
  .kivo-faq-list details {
    border: 1px solid rgba(44, 145, 255, 0.13);
    background: rgba(255, 255, 255, 0.84);
    box-shadow: none;
    backdrop-filter: blur(18px);
  }

  .kivo-confidence-strip article {
    border-radius: 0;
    padding: 0.72rem;
  }

  .kivo-confidence-strip span {
    display: inline-grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 900;
  }

  .kivo-confidence-strip strong {
    display: block;
    margin-top: 0.55rem;
    color: #102033;
    font-size: 1.05rem;
  }

  .kivo-confidence-strip p {
    margin-top: 0.2rem;
    color: #64778c;
  }

  .kivo-catalog__header {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    padding: 0.1rem 0.1rem 0.85rem;
  }

  .kivo-catalog__header h2 {
    margin-top: 0.35rem;
    font-size: clamp(1.8rem, 3vw, 3rem);
  }

  .kivo-catalog__header > p {
    color: #64778c;
    font-weight: 800;
  }

  .kivo-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(16rem, 100%), 1fr));
    gap: 0.75rem;
  }

  .kivo-product-tile {
    overflow: hidden;
    display: flex;
    min-width: 0;
    flex-direction: column;
    border: 1px solid rgba(44, 145, 255, 0.13);
    border-radius: 0;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .kivo-product-tile:hover {
    box-shadow: 0 22px 55px rgba(34, 91, 160, 0.15);
    transform: translateY(-4px);
  }

  .kivo-product-tile__image {
    display: grid;
    aspect-ratio: 1.08;
    place-items: center;
    background:
      radial-gradient(circle at 50% 12%, rgba(115, 192, 255, 0.28), transparent 12rem),
      #f7fbff;
  }

  .kivo-product-tile__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.8rem;
    transition: transform 220ms ease;
  }

  .kivo-product-tile:hover .kivo-product-tile__image img {
    transform: scale(1.035);
  }

  .kivo-product-tile__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 0.8rem;
  }

  .kivo-product-tile__badge {
    align-self: flex-start;
    align-self: stretch;
    justify-content: center;
    padding: 0.5rem 0.6rem;
    text-align: center;
  }

  .kivo-product-tile h3 {
    margin-top: 0.75rem;
    font-size: 1.08rem;
    line-height: 1.1;
  }

  .kivo-product-tile p {
    color: #64778c;
    font-size: 0.84rem;
    margin-top: 0.55rem;
  }

  .kivo-product-tile__footer {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1rem;
  }

  .kivo-product-tile__footer strong {
    color: #102033;
    color: #111111;
    font-size: 1.25rem;
  }

  .kivo-product-tile__footer strong s {
    margin-left: 0.45rem;
    color: #777777;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .kivo-product-tile__footer span {
    color: #111111;
    font-size: 0.88rem;
    font-weight: 900;
  }

  .kivo-store-info {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
    margin-top: 0.75rem;
  }

  .kivo-store-info article {
    padding: 0.75rem;
  }

  .kivo-store-info strong {
    display: block;
    color: #102033;
    font-size: 1.1rem;
  }

  .kivo-store-info p {
    color: #64778c;
    margin-top: 0.45rem;
  }

  .kivo-trust-panel,
  .kivo-faq {
    margin-top: 0.75rem;
    border: 1px solid rgba(44, 145, 255, 0.13);
    border-radius: 0;
    background: #ffffff;
    box-shadow: none;
    padding: 0.8rem;
  }

  .kivo-section-heading {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    padding: 0.1rem 0.1rem 0.65rem;
  }

  .kivo-section-heading h2 {
    max-width: none;
    margin-top: 0.2rem;
    font-size: clamp(1.25rem, 2vw, 1.8rem);
  }

  .kivo-trust-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .kivo-trust-grid article {
    display: flex;
    min-height: 3.1rem;
    align-items: center;
    gap: 0.45rem;
    border-radius: 0;
    padding: 0.55rem 0.6rem;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .kivo-trust-grid article:hover {
    box-shadow: none;
    transform: translateY(-1px);
  }

  .kivo-trust-grid article span {
    display: inline-grid;
    width: 1.35rem;
    height: 1.35rem;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-size: 0.75rem;
    font-weight: 900;
  }

  .kivo-trust-grid article strong {
    display: block;
    margin-top: 0;
    color: #111111;
    font-size: 0.82rem;
    line-height: 1.1;
  }

  .kivo-faq-list {
    display: grid;
    gap: 0.75rem;
  }

  .kivo-faq-list details {
    border-radius: 20px;
    padding: 1rem;
  }

  .kivo-faq-list summary {
    cursor: pointer;
    color: #102033;
    font-weight: 900;
  }

  .kivo-faq-list details p {
    margin-top: 0.7rem;
    color: #64778c;
  }

  @keyframes kivo-liquid-drift {
    from {
      border-radius: 42% 58% 63% 37% / 48% 43% 57% 52%;
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
    to {
      border-radius: 62% 38% 43% 57% / 39% 61% 39% 61%;
      transform: translate3d(1.5rem, -1rem, 0) rotate(8deg);
    }
  }

  @media (max-width: 980px) {
    .kivo-product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .kivo-shop-hero,
    .kivo-confidence-strip,
    .kivo-trust-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .kivo-shop-hero h1 {
      font-size: 3.25rem;
    }

    .kivo-catalog__header,
    .kivo-product-tile__footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .kivo-product-grid,
    .kivo-store-info {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "KivoRest storefront grid",
  "settings": [],
  "presets": [
    {
      "name": "KivoRest storefront grid"
    }
  ]
}
{% endschema %}
