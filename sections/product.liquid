{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}

<section class="kivo-product-page">
  <div class="kivo-product-gallery">
    {% if product.images.size > 0 %}
      <div class="kivo-product-gallery__main">
        {% render 'image', class: 'kivo-product-image-main', image: product.featured_image, width: 1200 %}
      </div>
      <div class="kivo-product-gallery__thumbs" aria-label="Imágenes del producto">
        {% for image in product.images limit: 6 %}
          {% render 'image', class: 'kivo-product-thumb', image: image, width: 360 %}
        {% endfor %}
      </div>
    {% else %}
      <div class="kivo-product-gallery__main kivo-product-gallery__fallback">
        <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="720" height="720">
      </div>
    {% endif %}
  </div>

  <div class="kivo-product-panel">
    <p class="kivo-product-eyebrow">KivoRest travel comfort</p>
    <h1>{{ product.title }}</h1>
    <div class="kivo-product-rating" aria-label="Customer rating">
      <span>★★★★★</span>
      <strong>Ready for long trips and quick getaways</strong>
    </div>
    <p class="kivo-product-price">{{ current_variant.price | money }}</p>

    <div class="kivo-product-description">
      {{ product.description }}
    </div>

    <div class="kivo-product-promises">
      <span>Adjustable firmness</span>
      <span>Lightweight and foldable</span>
      <span>Ideal for planes, cars, and camping</span>
    </div>

    <div class="kivo-product-form">
      {% form 'product', product %}
        <label for="Variant-{{ section.id }}">Color / variant</label>
        <select id="Variant-{{ section.id }}" name="id">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}
                selected="selected"
              {% endif %}
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {% endfor %}
        </select>

        <label for="Quantity-{{ section.id }}">Quantity</label>
        <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">

        <input type="submit" value="Add to cart">
        {{ form | payment_button }}
      {% endform %}
    </div>

    <div class="kivo-product-trust">
      <div>
        <strong>Easy to ship</strong>
        <span>Compact product with travel-friendly packaging.</span>
      </div>
      <div>
        <strong>Secure checkout</strong>
        <span>Payments protected by Shopify.</span>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .kivo-product-page {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    align-items: start;
    width: min(1180px, calc(100% - 32px));
    margin: 2rem auto 5rem;
  }

  .kivo-product-gallery,
  .kivo-product-panel {
    animation: kivo-product-rise 620ms ease both;
  }

  .kivo-product-panel {
    animation-delay: 90ms;
  }

  .kivo-product-gallery__main {
    overflow: hidden;
    display: grid;
    min-height: clamp(24rem, 54vw, 43rem);
    place-items: center;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 42px;
    background:
      radial-gradient(circle at 50% 16%, rgba(93, 180, 255, 0.35), transparent 18rem),
      linear-gradient(145deg, #ffffff, #eaf6ff);
    box-shadow: 0 30px 85px rgba(34, 91, 160, 0.14);
  }

  .kivo-product-image-main img {
    max-height: 42rem;
    object-fit: contain;
    padding: clamp(0.5rem, 2vw, 2rem);
    filter: drop-shadow(0 28px 48px rgba(34, 91, 160, 0.22));
    transition: transform 260ms ease;
  }

  .kivo-product-gallery__main:hover .kivo-product-image-main img {
    transform: scale(1.035) rotate(-0.7deg);
  }

  .kivo-product-gallery__fallback img {
    width: min(80%, 32rem);
    border-radius: 36px;
  }

  .kivo-product-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.65rem;
    margin-top: 0.75rem;
  }

  .kivo-product-thumb {
    overflow: hidden;
    aspect-ratio: 1;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 18px;
    background: #ffffff;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .kivo-product-thumb:hover {
    box-shadow: 0 12px 34px rgba(34, 91, 160, 0.14);
    transform: translateY(-3px);
  }

  .kivo-product-thumb img {
    height: 100%;
    object-fit: cover;
  }

  .kivo-product-panel {
    position: sticky;
    top: 7.5rem;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 36px;
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 30px 85px rgba(34, 91, 160, 0.12);
    backdrop-filter: blur(18px);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .kivo-product-eyebrow {
    color: #2c91ff;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kivo-product-panel h1 {
    margin-top: 0.65rem;
    color: #102033;
    font-size: clamp(2.35rem, 4.4vw, 4.8rem);
    letter-spacing: 0;
    line-height: 0.98;
  }

  .kivo-product-rating {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    margin-top: 1rem;
    color: #64778c;
  }

  .kivo-product-rating span {
    color: #2c91ff;
    letter-spacing: 0.08em;
  }

  .kivo-product-price {
    margin-top: 1.25rem;
    color: #102033;
    font-size: 2rem;
    font-weight: 900;
  }

  .kivo-product-description {
    max-height: 15rem;
    overflow: auto;
    margin-top: 1rem;
    color: #52657a;
    padding-right: 0.5rem;
  }

  .kivo-product-description :is(ul, ol) {
    padding-left: 1.25rem;
  }

  .kivo-product-promises {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .kivo-product-promises span {
    border-radius: 999px;
    background: #edf7ff;
    color: #315f8f;
    font-weight: 800;
    padding: 0.55rem 0.75rem;
  }

  .kivo-product-form {
    margin-top: 1.5rem;
  }

  .kivo-product-form form {
    display: grid;
    gap: 0.75rem;
  }

  .kivo-product-form label {
    color: #102033;
    font-weight: 900;
  }

  .kivo-product-form select,
  .kivo-product-form input[type="number"] {
    width: 100%;
    min-height: 3.1rem;
    border: 1px solid rgba(44, 145, 255, 0.2);
    border-radius: 18px;
    background: #ffffff;
    color: #102033;
    padding: 0.75rem 0.9rem;
  }

  .kivo-product-form input[type="submit"] {
    width: 100%;
    margin-top: 0.4rem;
  }

  .shopify-payment-button {
    margin-top: 0.2rem;
  }

  .shopify-payment-button__button {
    width: 100%;
    border-radius: 999px !important;
  }

  .shopify-payment-button__more-options {
    color: #52657a;
    margin-top: 0.75rem;
  }

  .kivo-product-trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .kivo-product-trust div {
    border-radius: 20px;
    background: #f5fbff;
    padding: 0.9rem;
  }

  .kivo-product-trust strong,
  .kivo-product-trust span {
    display: block;
  }

  .kivo-product-trust strong {
    color: #102033;
  }

  .kivo-product-trust span {
    color: #64778c;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  @keyframes kivo-product-rise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .kivo-product-page {
      grid-template-columns: 1fr;
    }

    .kivo-product-panel {
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 620px) {
    .kivo-product-page {
      margin-top: 1rem;
    }

    .kivo-product-gallery__main {
      min-height: 22rem;
      border-radius: 30px;
    }

    .kivo-product-gallery__thumbs,
    .kivo-product-trust {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
