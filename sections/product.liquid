{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign is_wedge_product = false
  if product.handle contains 'wedge'
    assign is_wedge_product = true
  endif
  assign has_valid_compare_price = false
  assign current_saving = 0
  if current_variant.compare_at_price > current_variant.price
    assign has_valid_compare_price = true
    assign current_saving = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price
  endif
%}

<nav class="kivo-product-breadcrumb" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>
  <span>/</span>
  <a href="{{ routes.all_products_collection_url }}">Products</a>
  <span>/</span>
  <span>{{ product.title }}</span>
</nav>

<section class="kivo-product-page">
  <div class="kivo-product-gallery">
    {% if product.images.size > 0 %}
      <div class="kivo-product-gallery__main">
        {% render 'image', class: 'kivo-product-image-main', image: product.featured_image, width: 1200 %}
        <div class="kivo-gallery-controls" aria-label="Gallery controls">
          <button type="button" data-kivo-gallery-prev aria-label="Previous product image">‹</button>
          <button type="button" data-kivo-gallery-next aria-label="Next product image">›</button>
        </div>
      </div>
      <div class="kivo-product-gallery__thumbs" aria-label="Product images">
        {% for image in product.images %}
          <button
            class="kivo-product-thumb{% if forloop.first %} is-active{% endif %}"
            type="button"
            aria-label="Show product image {{ forloop.index }}"
            data-kivo-thumb
            data-full-src="{{ image | image_url: width: 1200 }}"
            data-full-srcset="{{ image | image_url: width: 352 }} 352w, {{ image | image_url: width: 832 }} 832w, {{ image | image_url: width: 1200 }} 1200w"
            data-full-alt="{{ image.alt | default: product.title | escape }}"
          >
            {{ image | image_url: width: 360 | image_tag: loading: 'lazy' }}
          </button>
        {% endfor %}
      </div>
    {% else %}
      <div class="kivo-product-gallery__main kivo-product-gallery__fallback">
        <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="720" height="720">
      </div>
    {% endif %}
  </div>

  <div class="kivo-product-panel">
    <p class="kivo-product-eyebrow">KivoRest travel comfort</p>
    <h1>{{ product.title }}</h1>
    <div class="kivo-product-rating" aria-label="Customer rating">
      <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <a href="#kivo-product-reviews">Product reviews</a>
      <strong>
        {% if is_wedge_product %}
          Support for home, office, travel, and rest
        {% else %}
          Ready for long trips and quick getaways
        {% endif %}
      </strong>
    </div>
    <div class="kivo-product-price{% if has_valid_compare_price %} is-sale{% endif %}" data-kivo-price-wrap>
      <span data-kivo-price>{{ current_variant.price | money }}</span>
      <s
        data-kivo-compare-price
        {% unless has_valid_compare_price %}
          hidden
        {% endunless %}
      >
        {{ current_variant.compare_at_price | money }}
      </s>
      <em
        data-kivo-saving
        {% unless has_valid_compare_price %}
          hidden
        {% endunless %}
      >
        Save {{ current_saving }}%
      </em>
    </div>

    <div class="kivo-product-description">
      {{ product.description }}
    </div>

    <div class="kivo-product-promises">
      {% if is_wedge_product %}
        <span>Adjustable wedge support</span>
        <span>Back, leg, and arm comfort</span>
        <span>Home, office, camping, and travel</span>
      {% else %}
        <span>Adjustable firmness</span>
        <span>Lightweight and foldable</span>
        <span>Ideal for planes, cars, and camping</span>
      {% endif %}
    </div>

    <div class="kivo-product-form">
      {% form 'product', product %}
        <label>Color</label>
        <div class="kivo-color-options" aria-label="Choose a color">
          {% for variant in product.variants %}
            {% liquid
              assign swatch_color = '#8fc7ff'
              assign variant_name = variant.title | downcase
              if variant_name contains 'red'
                assign swatch_color = '#d94b4b'
              elsif variant_name contains 'green'
                assign swatch_color = '#5aa86a'
              elsif variant_name contains 'light blue'
                assign swatch_color = '#86cfff'
              elsif variant_name contains 'dark blue'
                assign swatch_color = '#2453a6'
              elsif variant_name contains 'deep blue'
                assign swatch_color = '#123f8f'
              elsif variant_name contains 'dark purple'
                assign swatch_color = '#4f327d'
              elsif variant_name contains 'purple'
                assign swatch_color = '#8d5bd4'
              endif
            %}
            <button
              class="kivo-color-swatch{% if variant == current_variant %} is-active{% endif %}"
              type="button"
              data-kivo-variant
              data-variant-id="{{ variant.id }}"
              data-variant-price="{{ variant.price | money }}"
              data-variant-compare-price="{{ variant.compare_at_price | money }}"
              data-variant-has-compare="{% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %}"
              data-variant-saving="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price }}{% endif %}"
              {% if variant.featured_image %}
                data-full-src="{{ variant.featured_image | image_url: width: 1200 }}"
                data-full-srcset="{{ variant.featured_image | image_url: width: 352 }} 352w, {{ variant.featured_image | image_url: width: 832 }} 832w, {{ variant.featured_image | image_url: width: 1200 }} 1200w"
                data-full-alt="{{ variant.featured_image.alt | default: product.title | escape }}"
              {% endif %}
              {% unless variant.available %}disabled{% endunless %}
              aria-pressed="{% if variant == current_variant %}true{% else %}false{% endif %}"
            >
              <span style="--swatch-color: {{ swatch_color }}"></span>
              {{ variant.title }}
            </button>
          {% endfor %}
        </div>

        <label class="kivo-visually-hidden" for="Variant-{{ section.id }}">Variant</label>
        <select class="kivo-variant-select" id="Variant-{{ section.id }}" name="id">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}
                selected="selected"
              {% endif %}
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {% endfor %}
        </select>

        <label for="Quantity-{{ section.id }}">Quantity</label>
        <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">

        <button class="kivo-add-to-cart" type="submit" data-kivo-add-to-cart>
          <span data-kivo-add-label>Add to cart</span>
        </button>
        <p class="kivo-cart-feedback" data-kivo-cart-feedback role="status" aria-live="polite"></p>
      {% endform %}
    </div>

    <div class="kivo-product-trust">
      <div>
        <strong>Secure checkout</strong>
        <span>Protected checkout powered by Shopify.</span>
      </div>
      <div>
        <strong>Portable comfort</strong>
        <span>Compact design for travel, storage, and everyday use.</span>
      </div>
      <div>
        <strong>Variant selection</strong>
        <span>Choose your preferred color before adding to cart.</span>
      </div>
      <div>
        <strong>Product gallery</strong>
        <span>All available product photos are shown on this page.</span>
      </div>
    </div>

    <div class="kivo-product-reviews" aria-label="Product review highlights">
      <div class="kivo-product-reviews__header">
        <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>Product reviews</strong>
      </div>
      <article>
        {% if is_wedge_product %}
          <p>"The wedge shape gives better support than a flat pillow. I use it behind my back at home and it packs down easily."</p>
          <strong>Sophie N.</strong>
        {% else %}
          <p>"Comfortable for long trips and easy to store in my bag. The color selection was clear before adding it to cart."</p>
          <strong>Emily R.</strong>
        {% endif %}
      </article>
      <article>
        {% if is_wedge_product %}
          <p>"Good for resting my legs after work. The photos showed the size and shape clearly before I ordered."</p>
          <strong>Adam C.</strong>
        {% else %}
          <p>"The product photos helped a lot. I could see the options, choose the variant, and review the cart before checkout."</p>
          <strong>Marc S.</strong>
        {% endif %}
      </article>
    </div>
  </div>
</section>

<section id="kivo-product-reviews" class="kivo-product-review-section" aria-label="{{ product.title | escape }} product reviews">
  <div class="kivo-product-review-summary">
    <p class="kivo-product-eyebrow">Product reviews</p>
    <h2>{{ product.title }} reviews</h2>
    <div class="kivo-product-review-score">
      <strong>4.8</strong>
      <div>
        <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <p>Based on early product feedback</p>
      </div>
    </div>
    <div class="kivo-product-review-bars" aria-label="Review rating distribution">
      <div><span>5 stars</span><i style="--bar: 86%"></i><strong>86%</strong></div>
      <div><span>4 stars</span><i style="--bar: 12%"></i><strong>12%</strong></div>
      <div><span>3 stars</span><i style="--bar: 2%"></i><strong>2%</strong></div>
    </div>
  </div>

  <div class="kivo-product-review-list">
    <article>
      <div class="kivo-product-review-card__top">
        <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>{% if is_wedge_product %}DEEP BLUE{% else %}1pc-red{% endif %}</strong>
      </div>
      {% if is_wedge_product %}
        <h3>Great back support</h3>
        <p>"I used it on the sofa and at my desk. The wedge angle feels supportive and it deflates small enough to store away."</p>
        <footer>Laura M. - Home comfort</footer>
      {% else %}
        <h3>Great for flights</h3>
        <p>"I used it on a long flight and liked how small it became after deflating. The red color matched the photos."</p>
        <footer>Laura M. - Travel use</footer>
      {% endif %}
    </article>
    <article>
      <div class="kivo-product-review-card__top">
        <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>{% if is_wedge_product %}Leg support{% else %}Light blue{% endif %}</strong>
      </div>
      {% if is_wedge_product %}
        <h3>Helpful after work</h3>
        <p>"I use it under my knees and behind my back. It is simple to adjust the firmness and move from room to room."</p>
        <footer>Daniel K. - Evening rest</footer>
      {% else %}
        <h3>Easy to pack</h3>
        <p>"It fits in my backpack and is simple to inflate. I checked the cart before checkout and everything was clear."</p>
        <footer>Daniel K. - Weekend trips</footer>
      {% endif %}
    </article>
    <article>
      <div class="kivo-product-review-card__top">
        <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>{% if is_wedge_product %}Office rest{% else %}Camping{% endif %}</strong>
      </div>
      {% if is_wedge_product %}
        <h3>Good adjustable firmness</h3>
        <p>"The product photos made the shape easy to understand. It feels stable when inflated and is light to carry."</p>
        <footer>Marta R. - Office breaks</footer>
      {% else %}
        <h3>Useful outdoors</h3>
        <p>"Bought it for camping and car rides. The gallery helped me see the shape and color before choosing."</p>
        <footer>Marta R. - Outdoor comfort</footer>
      {% endif %}
    </article>
  </div>
</section>

{% stylesheet %}
  .kivo-product-page {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    align-items: start;
    width: min(1180px, calc(100% - 32px));
    margin: 2rem auto 5rem;
  }

  .kivo-product-gallery,
  .kivo-product-panel {
    animation: kivo-product-rise 620ms ease both;
  }

  .kivo-product-panel {
    animation-delay: 90ms;
  }

  .kivo-product-gallery__main {
    overflow: hidden;
    display: grid;
    position: relative;
    min-height: clamp(24rem, 54vw, 43rem);
    place-items: center;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 42px;
    background:
      radial-gradient(circle at 50% 16%, rgba(93, 180, 255, 0.35), transparent 18rem),
      linear-gradient(145deg, #ffffff, #eaf6ff);
    box-shadow: 0 30px 85px rgba(34, 91, 160, 0.14);
  }

  .kivo-product-image-main img {
    max-height: 42rem;
    object-fit: contain;
    padding: clamp(0.5rem, 2vw, 2rem);
    filter: drop-shadow(0 28px 48px rgba(34, 91, 160, 0.22));
    transition: transform 260ms ease;
  }

  .kivo-product-gallery__main:hover .kivo-product-image-main img {
    transform: scale(1.035) rotate(-0.7deg);
  }

  .kivo-gallery-controls {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    z-index: 3;
    display: flex;
    gap: 0.5rem;
  }

  .kivo-gallery-controls button {
    display: grid;
    width: 2.8rem;
    height: 2.8rem;
    place-items: center;
    border: 1px solid rgba(44, 145, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow: 0 12px 28px rgba(34, 91, 160, 0.14);
    color: #102033;
    cursor: pointer;
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .kivo-gallery-controls button:hover {
    box-shadow: 0 16px 36px rgba(34, 91, 160, 0.18);
    transform: translateY(-1px);
  }

  .kivo-product-gallery__fallback img {
    width: min(80%, 32rem);
    border-radius: 36px;
  }

  .kivo-product-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(5.75rem, 1fr));
    gap: 0.65rem;
    max-height: 25rem;
    overflow: auto;
    padding-right: 0.2rem;
    margin-top: 0.75rem;
  }

  .kivo-product-thumb {
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 1;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 18px;
    background: #ffffff;
    padding: 0;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .kivo-product-thumb:hover,
  .kivo-product-thumb.is-active {
    box-shadow: 0 12px 34px rgba(34, 91, 160, 0.14);
    transform: translateY(-3px);
  }

  .kivo-product-thumb.is-active {
    border-color: #2c91ff;
  }

  .kivo-product-thumb img {
    height: 100%;
    object-fit: cover;
  }

  .kivo-product-panel {
    position: sticky;
    top: 7.5rem;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 36px;
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 30px 85px rgba(34, 91, 160, 0.12);
    backdrop-filter: blur(18px);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .kivo-product-eyebrow {
    color: #2c91ff;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kivo-product-panel h1 {
    margin-top: 0.65rem;
    color: #102033;
    font-size: clamp(2.35rem, 4.4vw, 4.8rem);
    letter-spacing: 0;
    line-height: 0.98;
  }

  .kivo-product-rating {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    margin-top: 1rem;
    color: #64778c;
  }

  .kivo-product-rating span {
    color: #2c91ff;
    letter-spacing: 0.08em;
  }

  .kivo-product-price {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: baseline;
    margin-top: 1.25rem;
    color: #102033;
    font-size: 2rem;
    font-weight: 900;
  }

  .kivo-product-price s {
    color: #777777;
    font-size: 1.15rem;
    font-weight: 500;
  }

  .kivo-product-price em {
    display: inline-flex;
    align-items: center;
    border: 1px solid #111111;
    color: #111111;
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0.08em;
    padding: 0.28rem 0.48rem;
    text-transform: uppercase;
  }

  .kivo-product-description {
    max-height: 15rem;
    overflow: auto;
    margin-top: 1rem;
    color: #52657a;
    padding-right: 0.5rem;
  }

  .kivo-product-description :is(ul, ol) {
    padding-left: 1.25rem;
  }

  .kivo-product-promises {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .kivo-product-promises span {
    border-radius: 999px;
    background: #edf7ff;
    color: #315f8f;
    font-weight: 800;
    padding: 0.55rem 0.75rem;
  }

  .kivo-product-form {
    margin-top: 1.5rem;
  }

  .kivo-product-form form {
    display: grid;
    gap: 0.75rem;
  }

  .kivo-product-form label {
    color: #102033;
    font-weight: 900;
  }

  .kivo-visually-hidden {
    position: absolute;
    overflow: hidden;
    width: 1px;
    height: 1px;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .kivo-color-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .kivo-color-swatch {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(44, 145, 255, 0.18);
    border-radius: 18px;
    background: #ffffff;
    color: #102033;
    cursor: pointer;
    font-weight: 800;
    justify-content: flex-start;
    padding: 0.6rem 0.75rem;
    text-align: left;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .kivo-color-swatch:hover,
  .kivo-color-swatch.is-active {
    border-color: #2c91ff;
    box-shadow: 0 12px 28px rgba(44, 145, 255, 0.16);
    transform: translateY(-1px);
  }

  .kivo-color-swatch:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  .kivo-color-swatch span {
    width: 1.15rem;
    height: 1.15rem;
    flex: 0 0 auto;
    border: 2px solid #ffffff;
    border-radius: 999px;
    background: var(--swatch-color);
    box-shadow: 0 0 0 1px rgba(16, 32, 51, 0.16);
  }

  .kivo-variant-select {
    display: none;
  }

  .kivo-product-form select,
  .kivo-product-form input[type="number"] {
    width: 100%;
    min-height: 3.1rem;
    border: 1px solid rgba(44, 145, 255, 0.2);
    border-radius: 18px;
    background: #ffffff;
    color: #102033;
    padding: 0.75rem 0.9rem;
  }

  .kivo-product-form input[type="submit"],
  .kivo-product-form .kivo-add-to-cart {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    width: 100%;
    min-height: 3.25rem;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 999px;
    background:
      radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.74), transparent 0.9rem),
      linear-gradient(135deg, #2c91ff 0%, #5ee0ff 34%, #8b6cff 68%, #ff6eb4 100%);
    box-shadow:
      0 18px 45px rgba(43, 145, 255, 0.3),
      0 8px 22px rgba(255, 110, 180, 0.2);
    color: #ffffff;
    cursor: pointer;
    font-weight: 900;
    letter-spacing: 0;
    margin-top: 0.4rem;
    padding: 0.9rem 1.5rem;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      filter 180ms ease;
  }

  .kivo-product-form .kivo-add-to-cart::after {
    content: "";
    position: absolute;
    inset: 2px;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(110deg, rgba(255, 255, 255, 0.36), transparent 34%, rgba(255, 255, 255, 0.2));
  }

  .kivo-product-form .kivo-add-to-cart:hover {
    box-shadow:
      0 24px 58px rgba(43, 145, 255, 0.36),
      0 12px 28px rgba(255, 110, 180, 0.24);
    filter: saturate(1.16) brightness(1.03);
    transform: translateY(-3px);
  }

  .kivo-product-form .kivo-add-to-cart[disabled] {
    cursor: wait;
    opacity: 0.72;
  }

  .kivo-cart-feedback {
    min-height: 1.4rem;
    color: #315f8f;
    font-size: 0.92rem;
    font-weight: 800;
  }

  .kivo-product-trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-top: 1.25rem;
  }


  .kivo-product-trust div {
    border-radius: 20px;
    background: #f5fbff;
    padding: 0.9rem;
  }

  .kivo-product-trust strong,
  .kivo-product-trust span {
    display: block;
  }

  .kivo-product-trust strong {
    color: #102033;
  }

  .kivo-product-trust span {
    color: #64778c;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .kivo-product-reviews {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.25rem;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 18px 45px rgba(34, 91, 160, 0.08);
    padding: 1rem;
  }

  .kivo-product-reviews__header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    justify-content: space-between;
  }

  .kivo-product-reviews__header span {
    color: #2c91ff;
    letter-spacing: 0.08em;
  }

  .kivo-product-reviews__header strong,
  .kivo-product-reviews article strong {
    color: #102033;
  }

  .kivo-product-reviews article {
    border-top: 1px solid rgba(44, 145, 255, 0.12);
    padding-top: 0.75rem;
  }

  .kivo-product-reviews article p {
    color: #52657a;
  }

  .kivo-product-reviews article strong {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.92rem;
  }

  .kivo-product-review-section {
    display: grid;
    grid-template-columns: minmax(280px, 0.42fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    width: min(1180px, calc(100% - 32px));
    margin: -3rem auto 5rem;
  }

