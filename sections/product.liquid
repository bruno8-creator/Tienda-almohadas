{% endstylesheet %}

{% javascript %}
  document.addEventListener('click', (event) => {
    const thumb = event.target.closest('[data-kivo-thumb]');
    const variantButton = event.target.closest('[data-kivo-variant]');
    const galleryNext = event.target.closest('[data-kivo-gallery-next]');
    const galleryPrev = event.target.closest('[data-kivo-gallery-prev]');
    const page = event.target.closest('.kivo-product-page');
    if (!page || (!thumb && !variantButton && !galleryNext && !galleryPrev)) return;

    const mainImage = page.querySelector('.kivo-product-image-main img');
    const price = page.querySelector('[data-kivo-price]');
    const comparePrice = page.querySelector('[data-kivo-compare-price]');
    const saving = page.querySelector('[data-kivo-saving]');
    const variantSelect = page.querySelector('select[name="id"]');

    const updateImage = (source) => {
      if (!mainImage || !source?.dataset.fullSrc) return;
      mainImage.src = source.dataset.fullSrc;
      if (source.dataset.fullSrcset) mainImage.srcset = source.dataset.fullSrcset;
      if (source.dataset.fullAlt) mainImage.alt = source.dataset.fullAlt;
    };

    if (thumb) {
      page.querySelectorAll('[data-kivo-thumb]').forEach((item) => item.classList.remove('is-active'));
      thumb.classList.add('is-active');
      updateImage(thumb);
    }

    if (galleryNext || galleryPrev) {
      const thumbs = Array.from(page.querySelectorAll('[data-kivo-thumb]'));
      if (thumbs.length) {
        const currentIndex = Math.max(0, thumbs.findIndex((item) => item.classList.contains('is-active')));
        const direction = galleryNext ? 1 : -1;
        const nextIndex = (currentIndex + direction + thumbs.length) % thumbs.length;
        thumbs[nextIndex].click();
      }
    }

    if (variantButton) {
      page.querySelectorAll('[data-kivo-variant]').forEach((item) => {
        item.classList.remove('is-active');
        item.setAttribute('aria-pressed', 'false');
      });
      variantButton.classList.add('is-active');
      variantButton.setAttribute('aria-pressed', 'true');

      if (variantSelect) {
        variantSelect.value = variantButton.dataset.variantId;
        variantSelect.dispatchEvent(new Event('change', { bubbles: true }));
      }

      if (price && variantButton.dataset.variantPrice) {
        price.textContent = variantButton.dataset.variantPrice;
      }

      if (comparePrice) {
        comparePrice.textContent = variantButton.dataset.variantComparePrice || '';
        comparePrice.hidden = variantButton.dataset.variantHasCompare !== 'true';
      }

      if (saving) {
        saving.textContent = `Save ${variantButton.dataset.variantSaving || 0}%`;
        saving.hidden = variantButton.dataset.variantHasCompare !== 'true';
      }

      updateImage(variantButton);
    }
  });

  document.addEventListener('submit', async (event) => {
    const form = event.target.closest('.kivo-product-form form');
    if (!form) return;

    event.preventDefault();

    const button = form.querySelector('[data-kivo-add-to-cart]');
    const label = form.querySelector('[data-kivo-add-label]');
    const feedback = form.querySelector('[data-kivo-cart-feedback]');
    const originalLabel = label?.textContent || 'Add to cart';

    if (button) button.disabled = true;
    if (label) label.textContent = 'Adding...';
    if (feedback) feedback.textContent = '';

    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          Accept: 'application/json',
        },
        body: new FormData(form),
      });

      if (!response.ok) {
        const error = await response.json().catch(() => ({}));
        throw new Error(error.description || 'Unable to add this item to cart.');
      }

      const cart = await fetch('/cart.js', {
        headers: { Accept: 'application/json' },
      }).then((cartResponse) => cartResponse.json());

      document.querySelectorAll('[data-cart-count]').forEach((counter) => {
        counter.textContent = cart.item_count;
        counter.hidden = cart.item_count === 0;
      });

      if (feedback) feedback.textContent = 'Added to cart.';
      if (label) label.textContent = 'Added';

      window.setTimeout(() => {
        window.location.href = '/cart';
      }, 550);
    } catch (error) {
      if (feedback) feedback.textContent = error.message;
      if (label) label.textContent = originalLabel;
      if (button) button.disabled = false;
    }
  });
{% endjavascript %}

