{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}

<section class="kivo-product-page">
  <div class="kivo-product-gallery">
    {% if product.images.size > 0 %}
      <div class="kivo-product-gallery__main">
        {% render 'image', class: 'kivo-product-image-main', image: product.featured_image, width: 1200 %}
        <div class="kivo-gallery-controls" aria-label="Gallery controls">
          <button type="button" data-kivo-gallery-prev aria-label="Previous product image">‹</button>
          <button type="button" data-kivo-gallery-next aria-label="Next product image">›</button>
        </div>
      </div>
      <div class="kivo-product-gallery__thumbs" aria-label="Product images">
        {% for image in product.images %}
          <button
            class="kivo-product-thumb{% if forloop.first %} is-active{% endif %}"
            type="button"
            aria-label="Show product image {{ forloop.index }}"
            data-kivo-thumb
            data-full-src="{{ image | image_url: width: 1200 }}"
            data-full-srcset="{{ image | image_url: width: 352 }} 352w, {{ image | image_url: width: 832 }} 832w, {{ image | image_url: width: 1200 }} 1200w"
            data-full-alt="{{ image.alt | default: product.title | escape }}"
          >
            {{ image | image_url: width: 360 | image_tag: loading: 'lazy' }}
          </button>
        {% endfor %}
      </div>
    {% else %}
      <div class="kivo-product-gallery__main kivo-product-gallery__fallback">
        <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="720" height="720">
      </div>
    {% endif %}
  </div>

  <div class="kivo-product-panel">
    <p class="kivo-product-eyebrow">KivoRest travel comfort</p>
    <h1>{{ product.title }}</h1>
    <div class="kivo-product-rating" aria-label="Customer rating">
      <span>★★★★★</span>
      <strong>Ready for long trips and quick getaways</strong>
    </div>
    <p class="kivo-product-price">{{ current_variant.price | money }}</p>

    <div class="kivo-product-description">
      {{ product.description }}
    </div>

    <div class="kivo-product-promises">
      <span>Adjustable firmness</span>
      <span>Lightweight and foldable</span>
      <span>Ideal for planes, cars, and camping</span>
    </div>

    <div class="kivo-product-form">
      {% form 'product', product %}
        <label>Color</label>
        <div class="kivo-color-options" aria-label="Choose a color">
          {% for variant in product.variants %}
            {% liquid
              assign swatch_color = '#8fc7ff'
              assign variant_name = variant.title | downcase
              if variant_name contains 'red'
                assign swatch_color = '#d94b4b'
              elsif variant_name contains 'green'
                assign swatch_color = '#5aa86a'
              elsif variant_name contains 'light blue'
                assign swatch_color = '#86cfff'
              elsif variant_name contains 'dark blue'
                assign swatch_color = '#2453a6'
              elsif variant_name contains 'dark purple'
                assign swatch_color = '#4f327d'
              elsif variant_name contains 'purple'
                assign swatch_color = '#8d5bd4'
              endif
            %}
            <button
              class="kivo-color-swatch{% if variant == current_variant %} is-active{% endif %}"
              type="button"
              data-kivo-variant
              data-variant-id="{{ variant.id }}"
              data-variant-price="{{ variant.price | money }}"
              {% if variant.featured_image %}
                data-full-src="{{ variant.featured_image | image_url: width: 1200 }}"
                data-full-srcset="{{ variant.featured_image | image_url: width: 352 }} 352w, {{ variant.featured_image | image_url: width: 832 }} 832w, {{ variant.featured_image | image_url: width: 1200 }} 1200w"
                data-full-alt="{{ variant.featured_image.alt | default: product.title | escape }}"
              {% endif %}
              {% unless variant.available %}disabled{% endunless %}
              aria-pressed="{% if variant == current_variant %}true{% else %}false{% endif %}"
            >
              <span style="--swatch-color: {{ swatch_color }}"></span>
              {{ variant.title }}
            </button>
          {% endfor %}
        </div>

        <label class="kivo-visually-hidden" for="Variant-{{ section.id }}">Variant</label>
        <select class="kivo-variant-select" id="Variant-{{ section.id }}" name="id">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}
                selected="selected"
              {% endif %}
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {% endfor %}
        </select>

        <label for="Quantity-{{ section.id }}">Quantity</label>
        <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">

        <input type="submit" value="Add to cart">
        {{ form | payment_button }}
      {% endform %}
    </div>

    <div class="kivo-product-payment">
      <strong>Secure payment options</strong>
      {% render 'kivorest-payment-badges' %}
      <p>Final payment options are shown at checkout based on your device, region, and Shopify payment settings.</p>
    </div>

    <div class="kivo-product-trust">
      <div>
        <strong>Secure checkout</strong>
        <span>Protected checkout powered by Shopify.</span>
      </div>
      <div>
        <strong>Portable comfort</strong>
        <span>Compact design for travel, storage, and everyday use.</span>
      </div>
      <div>
        <strong>Variant selection</strong>
        <span>Choose your preferred color before adding to cart.</span>
      </div>
      <div>
        <strong>Product gallery</strong>
        <span>All available product photos are shown on this page.</span>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .kivo-product-page {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    align-items: start;
    width: min(1180px, calc(100% - 32px));
    margin: 2rem auto 5rem;
  }

  .kivo-product-gallery,
  .kivo-product-panel {
    animation: kivo-product-rise 620ms ease both;
  }

  .kivo-product-panel {
    animation-delay: 90ms;
  }

  .kivo-product-gallery__main {
    overflow: hidden;
    display: grid;
    position: relative;
    min-height: clamp(24rem, 54vw, 43rem);
    place-items: center;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 42px;
    background:
      radial-gradient(circle at 50% 16%, rgba(93, 180, 255, 0.35), transparent 18rem),
      linear-gradient(145deg, #ffffff, #eaf6ff);
    box-shadow: 0 30px 85px rgba(34, 91, 160, 0.14);
  }

  .kivo-product-image-main img {
    max-height: 42rem;
    object-fit: contain;
    padding: clamp(0.5rem, 2vw, 2rem);
    filter: drop-shadow(0 28px 48px rgba(34, 91, 160, 0.22));
    transition: transform 260ms ease;
  }

  .kivo-product-gallery__main:hover .kivo-product-image-main img {
    transform: scale(1.035) rotate(-0.7deg);
  }

  .kivo-gallery-controls {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    z-index: 3;
    display: flex;
    gap: 0.5rem;
  }

  .kivo-gallery-controls button {
    display: grid;
    width: 2.8rem;
    height: 2.8rem;
    place-items: center;
    border: 1px solid rgba(44, 145, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow: 0 12px 28px rgba(34, 91, 160, 0.14);
    color: #102033;
    cursor: pointer;
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .kivo-gallery-controls button:hover {
    box-shadow: 0 16px 36px rgba(34, 91, 160, 0.18);
    transform: translateY(-1px);
  }

  .kivo-product-gallery__fallback img {
    width: min(80%, 32rem);
    border-radius: 36px;
  }

  .kivo-product-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(5.75rem, 1fr));
    gap: 0.65rem;
    max-height: 25rem;
    overflow: auto;
    padding-right: 0.2rem;
    margin-top: 0.75rem;
  }

  .kivo-product-thumb {
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 1;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 18px;
    background: #ffffff;
    padding: 0;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .kivo-product-thumb:hover,
  .kivo-product-thumb.is-active {
    box-shadow: 0 12px 34px rgba(34, 91, 160, 0.14);
    transform: translateY(-3px);
  }

  .kivo-product-thumb.is-active {
    border-color: #2c91ff;
  }

  .kivo-product-thumb img {
    height: 100%;
    object-fit: cover;
  }

  .kivo-product-panel {
    position: sticky;
    top: 7.5rem;
    border: 1px solid rgba(44, 145, 255, 0.14);
    border-radius: 36px;
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 30px 85px rgba(34, 91, 160, 0.12);
    backdrop-filter: blur(18px);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .kivo-product-eyebrow {
    color: #2c91ff;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kivo-product-panel h1 {
    margin-top: 0.65rem;
    color: #102033;
    font-size: clamp(2.35rem, 4.4vw, 4.8rem);
    letter-spacing: 0;
    line-height: 0.98;
  }

  .kivo-product-rating {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    margin-top: 1rem;
    color: #64778c;
  }

  .kivo-product-rating span {
    color: #2c91ff;
    letter-spacing: 0.08em;
  }

  .kivo-product-price {
    margin-top: 1.25rem;
    color: #102033;
    font-size: 2rem;
    font-weight: 900;
  }

  .kivo-product-description {
    max-height: 15rem;
    overflow: auto;
    margin-top: 1rem;
    color: #52657a;
    padding-right: 0.5rem;
  }

  .kivo-product-description :is(ul, ol) {
    padding-left: 1.25rem;
  }

  .kivo-product-promises {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .kivo-product-promises span {
    border-radius: 999px;
    background: #edf7ff;
    color: #315f8f;
    font-weight: 800;
    padding: 0.55rem 0.75rem;
  }

  .kivo-product-form {
    margin-top: 1.5rem;
  }

  .kivo-product-form form {
    display: grid;
    gap: 0.75rem;
  }

  .kivo-product-form label {
    color: #102033;
    font-weight: 900;
  }

  .kivo-visually-hidden {
    position: absolute;
    overflow: hidden;
    width: 1px;
    height: 1px;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .kivo-color-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .kivo-color-swatch {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(44, 145, 255, 0.18);
    border-radius: 18px;
    background: #ffffff;
    color: #102033;
    cursor: pointer;
    font-weight: 800;
    justify-content: flex-start;
    padding: 0.6rem 0.75rem;
    text-align: left;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .kivo-color-swatch:hover,
  .kivo-color-swatch.is-active {
    border-color: #2c91ff;
    box-shadow: 0 12px 28px rgba(44, 145, 255, 0.16);
    transform: translateY(-1px);
  }

  .kivo-color-swatch:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  .kivo-color-swatch span {
    width: 1.15rem;
    height: 1.15rem;
    flex: 0 0 auto;
    border: 2px solid #ffffff;
    border-radius: 999px;
    background: var(--swatch-color);
    box-shadow: 0 0 0 1px rgba(16, 32, 51, 0.16);
  }

  .kivo-variant-select {
    display: none;
  }

  .kivo-product-form select,
  .kivo-product-form input[type="number"] {
    width: 100%;
    min-height: 3.1rem;
    border: 1px solid rgba(44, 145, 255, 0.2);
    border-radius: 18px;
    background: #ffffff;
    color: #102033;
    padding: 0.75rem 0.9rem;
  }

  .kivo-product-form input[type="submit"] {
    width: 100%;
    margin-top: 0.4rem;
  }

  .shopify-payment-button {
    margin-top: 0.2rem;
  }

  .shopify-payment-button__button {
    width: 100%;
    border-radius: 999px !important;
  }

  .shopify-payment-button__more-options {
    color: #52657a;
    margin-top: 0.75rem;
  }

  .kivo-product-trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .kivo-product-payment {
    margin-top: 1.25rem;
    border-radius: 22px;
    background: #f5fbff;
    padding: 1rem;
  }

  .kivo-product-payment > strong {
    display: block;
    color: #102033;
    margin-bottom: 0.65rem;
  }

  .kivo-product-payment p {
    color: #64778c;
    font-size: 0.88rem;
    margin-top: 0.7rem;
  }

  .kivo-product-trust div {
    border-radius: 20px;
    background: #f5fbff;
    padding: 0.9rem;
  }

  .kivo-product-trust strong,
  .kivo-product-trust span {
    display: block;
  }

  .kivo-product-trust strong {
    color: #102033;
  }

  .kivo-product-trust span {
    color: #64778c;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  @keyframes kivo-product-rise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .kivo-product-page {
      grid-template-columns: 1fr;
    }

    .kivo-product-panel {
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 620px) {
    .kivo-product-page {
      margin-top: 1rem;
    }

    .kivo-product-gallery__main {
      min-height: 22rem;
      border-radius: 30px;
    }

    .kivo-product-gallery__thumbs,
    .kivo-product-trust {
      grid-template-columns: repeat(2, 1fr);
    }

    .kivo-product-gallery__thumbs {
      max-height: none;
      overflow: visible;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('click', (event) => {
    const thumb = event.target.closest('[data-kivo-thumb]');
    const variantButton = event.target.closest('[data-kivo-variant]');
    const galleryNext = event.target.closest('[data-kivo-gallery-next]');
    const galleryPrev = event.target.closest('[data-kivo-gallery-prev]');
    const page = event.target.closest('.kivo-product-page');
    if (!page || (!thumb && !variantButton && !galleryNext && !galleryPrev)) return;

    const mainImage = page.querySelector('.kivo-product-image-main img');
    const price = page.querySelector('.kivo-product-price');
    const variantSelect = page.querySelector('select[name="id"]');

    const updateImage = (source) => {
      if (!mainImage || !source?.dataset.fullSrc) return;
      mainImage.src = source.dataset.fullSrc;
      if (source.dataset.fullSrcset) mainImage.srcset = source.dataset.fullSrcset;
      if (source.dataset.fullAlt) mainImage.alt = source.dataset.fullAlt;
    };

    if (thumb) {
      page.querySelectorAll('[data-kivo-thumb]').forEach((item) => item.classList.remove('is-active'));
      thumb.classList.add('is-active');
      updateImage(thumb);
    }

    if (galleryNext || galleryPrev) {
      const thumbs = Array.from(page.querySelectorAll('[data-kivo-thumb]'));
      if (thumbs.length) {
        const currentIndex = Math.max(0, thumbs.findIndex((item) => item.classList.contains('is-active')));
        const direction = galleryNext ? 1 : -1;
        const nextIndex = (currentIndex + direction + thumbs.length) % thumbs.length;
        thumbs[nextIndex].click();
      }
    }

    if (variantButton) {
      page.querySelectorAll('[data-kivo-variant]').forEach((item) => {
        item.classList.remove('is-active');
        item.setAttribute('aria-pressed', 'false');
      });
      variantButton.classList.add('is-active');
      variantButton.setAttribute('aria-pressed', 'true');

      if (variantSelect) {
        variantSelect.value = variantButton.dataset.variantId;
        variantSelect.dispatchEvent(new Event('change', { bubbles: true }));
      }

      if (price && variantButton.dataset.variantPrice) {
        price.textContent = variantButton.dataset.variantPrice;
      }

      updateImage(variantButton);
    }
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
