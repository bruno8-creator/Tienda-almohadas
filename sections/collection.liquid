{% comment %}
  This section is used in the collection template to render collection page
  listing all products within a collection.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<section class="kivo-collection-page">
  <div class="kivo-collection-header">
    <p>Products</p>
    <h1>{{ collection.title }}</h1>
  </div>

  <div class="collection-products">
  {% paginate collection.products by 20 %}
    {% for product in collection.products %}
      {% liquid
        assign kivo_discount_percent = 50
        assign kivo_discount_multiplier = 100 | minus: kivo_discount_percent
        assign collection_campaign_price = product.price | times: kivo_discount_multiplier | plus: 50 | divided_by: 100
        assign collection_badge = '50% off in cart'
      %}
      <a class="collection-product" href="{{ product.url }}">
        {% if product.featured_image %}
          {% render 'image',
            class: 'collection-product__image',
            image: product.featured_image,
            width: 400,
            height: 400,
            crop: 'center'
          %}
        {% endif %}
        <div class="collection-product__content">
          <span>{{ collection_badge }}</span>
          <h2>{{ product.title | escape }}</h2>
          <p>
            {{ collection_campaign_price | money }}
            <s>{{ product.price | money }}</s>
          </p>
        </div>
      </a>
    {% endfor %}

    {{ paginate | default_pagination }}
  {% endpaginate %}
  </div>
</section>

{% stylesheet %}
  .kivo-collection-page {
    width: min(1180px, calc(100% - 32px));
    margin: 2rem auto 5rem;
  }

  .kivo-collection-header {
    margin-bottom: 1rem;
  }

  .kivo-collection-header p {
    color: #2c91ff;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .kivo-collection-header h1 {
    color: #102033;
    font-size: clamp(2.4rem, 5vw, 5rem);
    letter-spacing: 0;
    line-height: 1;
    margin-top: 0.5rem;
  }

  .collection-products {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .collection-product {
    overflow: hidden;
    display: flex;
    min-width: 0;
    flex-direction: column;
    border: 1px solid rgba(44, 145, 255, 0.13);
    border-radius: 22px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 50px rgba(34, 91, 160, 0.08);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .collection-product:hover {
    box-shadow: 0 22px 55px rgba(34, 91, 160, 0.15);
    transform: translateY(-4px);
  }

  .collection-product__image {
    aspect-ratio: 1;
    background: #f7fbff;
  }

  .collection-product__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.8rem;
  }

  .collection-product__content {
    padding: 1rem;
  }

  .collection-product__content span {
    display: inline-flex;
    border: 1px solid #111111;
    border-radius: 0;
    background: #111111;
    color: #ffffff;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    padding: 0.4rem 0.58rem;
    text-transform: uppercase;
  }

  .collection-product__content h2 {
    color: #102033;
    font-size: 1.2rem;
    letter-spacing: 0;
    line-height: 1.1;
    margin-top: 0.75rem;
  }

  .collection-product__content p {
    color: #102033;
    font-size: 1.2rem;
    font-weight: 900;
    margin-top: 0.7rem;
  }

  .collection-product__content p s {
    margin-left: 0.45rem;
    color: #777777;
    font-size: 0.92rem;
    font-weight: 500;
  }

  @media (max-width: 980px) {
    .collection-products {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .collection-products {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
