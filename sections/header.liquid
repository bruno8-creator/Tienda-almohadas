<div class="kivo-announcement" aria-label="Store benefits">
  <span>Free shipping over EUR 50</span>
  <span>Launch collection now live</span>
  <span>Secure Shopify checkout</span>
</div>

<header>
  <a class="header__brand" href="{{ routes.root_url }}" aria-label="KivoRest">
    <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="48" height="48">
    <span>KivoRest</span>
  </a>

  <div class="header__menu">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="{{ routes.all_products_collection_url }}">Shop</a>
    <a href="{{ routes.all_products_collection_url }}">Bestsellers</a>
    <a href="{{ routes.root_url }}#kivo-confidence">About</a>
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a class="header__cart" href="{{ routes.cart_url }}" aria-label="Cart">
      <sup data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</sup>

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  .kivo-announcement {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    min-height: 2.8rem;
    align-items: center;
    background: #000000;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
  }

  .kivo-announcement span + span {
    border-left: 1px solid rgba(255, 255, 255, 0.32);
  }

  header {
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: 5.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    width: 100%;
    margin: 0;
    padding: 0.9rem clamp(1rem, 4vw, 3.2rem);
    border-bottom: 1px solid #eeeeee;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: none;
    backdrop-filter: blur(12px);
  }

  header a {
    position: relative;
    text-decoration: none;
    color: #102033;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  header .header__brand {
    gap: 0.65rem;
    color: #111111;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  header .header__brand img {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 12px;
    object-fit: cover;
  }

  header a sup {
    position: absolute;
    top: -0.55rem;
    right: -0.55rem;
    overflow: hidden;
    display: grid;
    min-width: 1.25rem;
    height: 1.25rem;
    place-items: center;
    border-radius: 999px;
    background: #111111;
    color: #fff;
    font-size: 0.75rem;
  }

  header svg {
    width: 1.65rem;
  }

  header .header__menu,
  header .header__icons {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  header .header__menu a {
    color: #222222;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.45rem 0.65rem;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  header .header__menu a:hover {
    color: #777777;
    transform: translateY(-1px);
  }

  header .header__cart {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    background: #ffffff;
  }

  @media (max-width: 760px) {
    .kivo-announcement {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      padding: 0.55rem 1rem;
    }

    .kivo-announcement span + span {
      border-left: 0;
    }

    header {
      flex-wrap: wrap;
    }

    header .header__menu {
      order: 3;
      width: 100%;
      justify-content: space-between;
    }

    header .header__menu a {
      padding-inline: 0.45rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
