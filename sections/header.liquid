<header>
  <a class="header__brand" href="{{ routes.root_url }}" aria-label="KivoRest">
    <img src="{{ 'kivorest-logo.png' | asset_url }}" alt="KivoRest" width="48" height="48">
    <span>KivoRest</span>
  </a>

  <div class="header__menu">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="{{ routes.all_products_collection_url }}">Products</a>
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a class="header__cart" href="{{ routes.cart_url }}" aria-label="Cart">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  header {
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    width: min(1180px, calc(100% - 32px));
    margin: 0.75rem auto;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(66, 154, 248, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 20px 60px rgba(34, 91, 160, 0.12);
    backdrop-filter: blur(18px);
  }

  header a {
    position: relative;
    text-decoration: none;
    color: #102033;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  header .header__brand {
    gap: 0.65rem;
    font-size: 1.15rem;
    font-weight: 900;
  }

  header .header__brand img {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 16px;
    object-fit: cover;
  }

  header a sup {
    position: absolute;
    top: -0.55rem;
    right: -0.55rem;
    overflow: hidden;
    display: grid;
    min-width: 1.25rem;
    height: 1.25rem;
    place-items: center;
    border-radius: 999px;
    background: #2c91ff;
    color: #fff;
    font-size: 0.75rem;
  }

  header svg {
    width: 1.65rem;
  }

  header .header__menu,
  header .header__icons {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  header .header__menu a {
    border-radius: 999px;
    color: #52657a;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.65rem 0.85rem;
    transition:
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  header .header__menu a:hover {
    background: #edf7ff;
    color: #102033;
    transform: translateY(-1px);
  }

  header .header__cart {
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 999px;
    background: #f1f8ff;
  }

  @media (max-width: 760px) {
    header {
      border-radius: 28px;
      flex-wrap: wrap;
    }

    header .header__menu {
      order: 3;
      width: 100%;
      justify-content: space-between;
    }

    header .header__menu a {
      padding-inline: 0.45rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
